# Shared
NODE_ENV=development

# Backend
PORT=8787
CORS_ORIGIN=http://localhost:5173
# Production durability. Railway Postgres injects this automatically when attached.
DATABASE_URL=
# Local fallback only when DATABASE_URL is not set.
DATA_DIR=server/data

# 0G mainnet production target
ZG_NETWORK=mainnet
ZG_RPC_URL=https://evmrpc.0g.ai
ZG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai
ZG_CHAIN_ID=16661
ZG_EXPLORER_URL=https://chainscan.0g.ai
ZG_STORAGE_EXPLORER_URL=https://storagescan.0g.ai
ZG_PRIVATE_KEY=
ZG_REGISTRY_CONTRACT=
ZG_REGISTRY_FROM_BLOCK=0

# 0G Compute Router
ZG_COMPUTE_API_KEY=
ZG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
ZG_COMPUTE_TRUST_MODE=verified
# 0G model policy by API lane. Values are model IDs from the 0G console allowlist.
ZEROSCOUT_HELPER_MODEL=claude-fable-5
ZEROSCOUT_LP_MODEL=claude-fable-5
ZEROSCOUT_LP_VERIFIER_MODEL=glm-5.2
ZEROSCOUT_LP_VERIFIER_ENABLED=false
ZEROSCOUT_FULL_PLATFORM_MODEL=glm-5.2
ZG_COMPUTE_VIDEO_MODEL=qwen3-vl-30b
# Optional alias used by HashpayStream Agent Hash media inspection.
ZEROSCOUT_HASHWATCH_MEDIA_MODEL=qwen3-vl-30b
# Legacy alias; keep unset unless you intentionally want one default for all non-lane routes.
ZG_COMPUTE_MODEL=
# External OpenAI/Anthropic reviewers are disabled by default. Keep false for 0G-only production positioning.
ZEROSCOUT_ENABLE_EXTERNAL_REVIEWERS=false

# Partner/API administration
# Used by ZeroScout operators to issue or revoke named partner keys.
ZEROSCOUT_ADMIN_TOKEN=
# Legacy single shared integration secret. Prefer named keys from /api/admin/integration-keys.
ZEROSCOUT_INTEGRATION_SECRET=
# Native OG top-ups for self-serve API credits.
ZEROSCOUT_TREASURY_ADDRESS=
ZEROSCOUT_CREDITS_PER_OG=100

# Optional external AI fallback. Disabled unless ZEROSCOUT_ENABLE_EXTERNAL_REVIEWERS=true.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Local development only. Do not use for production or submitted demo claims.
DEV_STORAGE_FALLBACK=false

# Frontend
VITE_API_BASE_URL=http://localhost:8787
# Optional Privy wallet onboarding. Keep disabled until Privy domains are configured.
VITE_ENABLE_PRIVY=false
VITE_PRIVY_APP_ID=
