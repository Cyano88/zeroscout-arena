{
  "name": "zeroscout-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node dist/server/server/src/index.js",
    "deploy:registry": "tsx scripts/deploy-registry.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.json",
    "lint": "eslint . --ext ts,tsx --max-warnings 0"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.6",
    "@privy-io/react-auth": "^3.32.2",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "6.13.1",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "nanoid": "^5.0.9",
    "openai": "^4.77.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "tsx": "^4.19.2",
    "vite": "^6.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.17.0",
    "solc": "^0.8.35",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "axios": "1.18.1",
    "ws": "8.21.0"
  }
}
